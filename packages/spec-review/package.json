{
  "name": "@wifo/factory-spec-review",
  "version": "0.0.7",
  "description": "LLM-judged spec quality reviewer — runs subscription-paid `claude -p` judges against software-factory specs and emits findings in factory-spec-lint's output format",
  "license": "MIT",
  "author": "Luis (WiFoDev)",
  "homepage": "https://github.com/WiFoDev/software-factory/tree/main/packages/spec-review#readme",
  "bugs": {
    "url": "https://github.com/WiFoDev/software-factory/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WiFoDev/software-factory.git",
    "directory": "packages/spec-review"
  },
  "keywords": [
    "software-factory",
    "agents",
    "spec-driven",
    "spec-review",
    "judge",
    "llm",
    "claude"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "factory-spec-review": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test src"
  },
  "dependencies": {
    "@wifo/factory-core": "workspace:*",
    "@wifo/factory-harness": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14"
  }
}
