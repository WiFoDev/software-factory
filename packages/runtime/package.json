{
  "name": "@wifo/factory-runtime",
  "version": "0.0.9",
  "description": "Phase-graph runtime that composes core/harness/twin/context into an end-to-end agent pipeline — explore, plan, implement, validate, iterate until scenarios converge",
  "license": "MIT",
  "author": "Luis (WiFoDev)",
  "homepage": "https://github.com/WiFoDev/software-factory/tree/main/packages/runtime#readme",
  "bugs": {
    "url": "https://github.com/WiFoDev/software-factory/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WiFoDev/software-factory.git",
    "directory": "packages/runtime"
  },
  "keywords": [
    "software-factory",
    "agents",
    "spec-driven",
    "runtime",
    "phase-graph",
    "orchestrator",
    "claude"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "factory-runtime": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test src"
  },
  "dependencies": {
    "@wifo/factory-context": "workspace:*",
    "@wifo/factory-core": "workspace:*",
    "@wifo/factory-harness": "workspace:*",
    "@wifo/factory-twin": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14"
  }
}
