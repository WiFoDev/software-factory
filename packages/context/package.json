{
  "name": "@wifo/factory-context",
  "version": "0.0.7",
  "description": "Filesystem-first context store — typed shared memory for agent phases, with content-addressable records and a DAG of provenance",
  "license": "MIT",
  "author": "Luis (WiFoDev)",
  "homepage": "https://github.com/WiFoDev/software-factory/tree/main/packages/context#readme",
  "bugs": {
    "url": "https://github.com/WiFoDev/software-factory/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WiFoDev/software-factory.git",
    "directory": "packages/context"
  },
  "keywords": [
    "software-factory",
    "agents",
    "spec-driven",
    "context",
    "content-addressable",
    "provenance",
    "dag"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "factory-context": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test src"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14"
  }
}
